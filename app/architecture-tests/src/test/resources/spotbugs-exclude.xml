<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
    <!-- Exclude all test classes from SpotBugs analysis -->
    <Match>
        <Class name="~.*Test.*"/>
    </Match>
    
    <Match>
        <Class name="~.*Tests.*"/>
    </Match>
    
    <!-- Exclude ArchTest classes -->
    <Match>
        <Class name="~.*ArchTest.*"/>
    </Match>
    
    <!-- Exclude architecture test packages -->
    <Match>
        <Package name="~dk\.jnie\.example\.architecture.*"/>
    </Match>
    
    <!-- Disable all checks in test scope - tests don't need static analysis -->
    <Match>
        <Source name="~.*Test\.java"/>
    </Match>
</FindBugsFilter>